    "table_cell_accuracy": { "direction": "higher", "max_regression": 0.03, "required": false },
    "table_span_accuracy": { "direction": "higher", "max_regression": 0.03, "required": false },
    "table_role_accuracy": { "direction": "higher", "max_regression": 0.03, "required": false },
    "table_rowspan_accuracy": { "direction": "higher", "max_regression": 0.03, "required": false },
    "table_colspan_accuracy": { "direction": "higher", "max_regression": 0.03, "required": false },
    "table_page_accuracy": { "direction": "higher", "max_regression": 0.03, "required": false },
    "table_continuation_accuracy": { "direction": "higher", "max_regression": 0.03, "required": false },
    "table_source_span_coverage": { "direction": "higher", "max_regression": 0.05, "required": false },
    "formula_structure_accuracy": { "direction": "higher", "max_regression": 0.03, "required": false },
